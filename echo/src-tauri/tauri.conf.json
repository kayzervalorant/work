{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Echo",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": false,
        "request": true,
        "scope": ["http://localhost:8000/*"]
      },
      "dialog": {
        "all": false,
        "open": true
      },
      "shell": {
        "all": false,
        "open": true,
        "sidecar": true,
        "scope": [
          { "name": "echo-backend", "sidecar": true },
          { "name": "open-url", "cmd": "open", "args": true }
        ]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "ai.echo.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/echo-backend"
      ],
      "shortDescription": "Assistant IA local privacy-first",
      "longDescription": "Echo est un assistant IA entièrement local. Vos documents ne quittent jamais votre machine. Propulsé par Ollama et ChromaDB.",
      "copyright": "Echo",
      "category": "Productivity",
      "windows": {
        "nsis": {
          "languages": ["French"],
          "installMode": "currentUser"
        }
      },
      "macOS": {
        "minimumSystemVersion": "10.15",
        "signingIdentity": null,
        "entitlements": null
      }
    },
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src 'self' http://localhost:8000 http://localhost:11434; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Echo",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "center": true,
        "fileDropEnabled": true
      }
    ]
  }
}

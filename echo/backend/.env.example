# ─────────────────────────────────────────────
# Echo Backend — Variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs
# ─────────────────────────────────────────────

# Dossier des documents à indexer
ECHO_DOCS_DIR=./docs

# Dossier de persistance ChromaDB
ECHO_CHROMA_DIR=./chroma_db

# URL d'Ollama (local par défaut)
OLLAMA_BASE_URL=http://localhost:11434

# Modèle de génération
OLLAMA_MODEL=mistral

# Modèle d'embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text

# Origines CORS autorisées (séparées par des virgules)
# :1420 = Tauri desktop  |  :5173 = Vite dev browser
ECHO_CORS_ORIGINS=http://localhost:1420,http://localhost:5173
